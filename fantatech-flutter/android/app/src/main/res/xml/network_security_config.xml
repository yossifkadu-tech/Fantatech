<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext (HTTP) traffic only to private LAN ranges and .local mDNS
  hosts (e.g. homeassistant.local). Public internet stays HTTPS-only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- mDNS / Bonjour hostnames (homeassistant.local, etc.) -->
        <domain includeSubdomains="true">local</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="true">
        <!-- RFC-1918 Class A: 10.0.0.0/8 -->
        <domain includeSubdomains="true">10.0.0.0</domain>
    </domain-config>

    <!-- Android network-security-config does not support CIDR ranges for
         IP addresses, so we allow cleartext globally for private subnets
         via the base-config. Public traffic (cloud) is still HTTPS-only
         because FantaTech's own backend uses HTTPS. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
